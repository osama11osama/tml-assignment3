executable = /bin/bash
arguments = /home/YOUR_CLUSTER_USER/tml26_task3/scripts/cluster/run_erm_chunk.sh 60
output = /home/YOUR_CLUSTER_USER/tml26_task3/runlogs/erm_r34_chunk60.$(ClusterId).out
